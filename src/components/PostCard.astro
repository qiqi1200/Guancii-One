---
import type { CollectionEntry } from 'astro:content';
import site from '../site.json';
const SITE = site;

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { data, slug } = post;
const url = `/posts/${slug}/`;

// 估算阅读时间
const wordCount = (post.body || '').length;
const readTime = Math.max(1, Math.ceil(wordCount / 400));

const dateStr = data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<article class={`group card-hover ${featured ? 'md:col-span-2' : ''}`}>
  <a href={url} class="block">
    {data.cover && (
      <div class="overflow-hidden rounded-xl mb-4 aspect-[16/9] bg-cream-100 dark:bg-ink-600">
        <img
          src={data.cover}
          alt={data.title}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    )}
    <div class="space-y-3">
      <div class="flex items-center gap-2 flex-wrap text-xs text-ink-400 dark:text-cream-300">
        <time datetime={data.date.toISOString()}>{dateStr}</time>
        <span>·</span>
        <span>{readTime} 分钟阅读</span>
        {data.tags && data.tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-1.5 flex-wrap">
              {data.tags.slice(0, 2).map(t => (
                <span class="tag-chip">#{t}</span>
              ))}
            </div>
          </>
        )}
      </div>

      <h3 class={`font-semibold tracking-tight text-ink-700 dark:text-cream-50 group-hover:text-accent-sky transition-colors ${featured ? 'text-2xl md:text-3xl' : 'text-lg'}`}>
        {data.title}
      </h3>

      {data.description && (
        <p class="text-ink-500 dark:text-cream-300 line-clamp-2 leading-relaxed text-sm">
          {data.description}
        </p>
      )}

      <div class="flex items-center text-accent-sky text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
        阅读全文 →
      </div>
    </div>
  </a>
</article>
