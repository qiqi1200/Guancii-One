---
import type { CollectionEntry } from 'astro:content';
import site from '../site.json';
const SITE = site;

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

// 按标签统计
const tagMap = new Map<string, number>();
posts.forEach(p => {
  p.data.tags?.forEach(t => {
    tagMap.set(t, (tagMap.get(t) || 0) + 1);
  });
});
const tags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// 最新文章
const recent = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

// 归档
const archiveMap = new Map<string, number>();
posts.forEach(p => {
  const key = p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
  archiveMap.set(key, (archiveMap.get(key) || 0) + 1);
});
const archives = [...archiveMap.entries()].slice(0, 8);
---

<div id="sidebar" class="w-full">
  <!-- 个人信息卡片 (Fuwaari-style profile) -->
  <div class="card-base p-4 mb-4 onload-animation">
    <a href="/about" class="group block relative overflow-hidden rounded-2xl ios-press mb-4">
      <img
        src={SITE.avatar}
        alt={SITE.author}
        class="w-full h-auto rounded-xl"
      />
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all flex items-center justify-center">
        <span class="material-symbols-outlined text-white text-4xl opacity-0 group-hover:opacity-100 transition-opacity">person</span>
      </div>
    </a>
    <div class="text-center">
      <div class="font-headline font-bold text-lg text-[rgb(var(--fg))] mb-1">{SITE.author}</div>
      <div class="h-1 w-8 bg-[rgb(var(--primary))] mx-auto rounded-full mb-2"></div>
      <div class="text-sm text-[rgb(var(--fg-soft))] mb-3">{SITE.description}</div>
      <div class="flex justify-center gap-2">
        <a href={SITE.links.github} target="_blank" rel="noopener"
           class="w-9 h-9 rounded-2xl flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.1)] transition-all ios-press-light">
          <span class="material-symbols-outlined text-lg">code</span>
        </a>
        <a href={SITE.links.email}
           class="w-9 h-9 rounded-2xl flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.1)] transition-all ios-press-light">
          <span class="material-symbols-outlined text-lg">mail</span>
        </a>
        <a href="/rss.xml"
           class="w-9 h-9 rounded-2xl flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.1)] transition-all ios-press-light">
          <span class="material-symbols-outlined text-lg">rss_feed</span>
        </a>
      </div>
    </div>
  </div>

  <!-- 侧边栏粘性区域 -->
  <div id="sidebar-sticky" class="flex flex-col gap-4 sticky top-24 transition-all duration-700">
    <!-- 搜索 -->
    <section class="card-base p-4 onload-animation" style="animation-delay: 100ms">
      <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
        <span class="flex items-center gap-1.5">
          <span class="material-symbols-outlined text-sm">search</span>
          搜索
        </span>
      </h4>
      <form action="/search" method="get" class="relative">
        <input
          type="search"
          name="q"
          placeholder="搜索文章..."
          class="w-full pl-9 pr-3 py-2 rounded-lg bg-[rgb(var(--bg-soft))] border border-[rgb(var(--border))]/50 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--fg-soft))] focus:outline-none focus:border-[rgb(var(--primary))] focus:ring-1 focus:ring-[rgb(var(--primary))]/30 transition-colors"
        />
        <span class="material-symbols-outlined absolute left-2.5 top-2 text-sm text-[rgb(var(--fg-soft))]">search</span>
      </form>
    </section>

    <!-- 标签云 -->
    {tags.length > 0 && (
      <section class="card-base p-4 onload-animation" style="animation-delay: 150ms">
        <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">local_offer</span>
            标签
          </span>
        </h4>
        <div class="flex flex-wrap gap-1.5">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${tag}`} class="tag-chip">
              #{tag} <span class="opacity-50 ml-0.5">{count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 最新文章 -->
    {recent.length > 0 && (
      <section class="card-base p-4 onload-animation" style="animation-delay: 200ms">
        <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">article</span>
            最新
          </span>
        </h4>
        <ul class="space-y-3">
          {recent.map(p => (
            <li>
              <a href={`/posts/${p.slug}/`} class="block group">
                <div class="text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors font-medium line-clamp-2 leading-snug text-sm">
                  {p.data.title}
                </div>
                <div class="flex items-center gap-2 mt-0.5 text-xs text-[rgb(var(--fg-soft))]">
                  <span>{p.data.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}</span>
                  {p.data.tags && p.data.tags.length > 0 && (
                    <span class="flex gap-1 flex-wrap">
                      {p.data.tags.slice(0, 2).map(t => (
                        <span class="opacity-60">#{t}</span>
                      ))}
                    </span>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- 归档 -->
    {archives.length > 0 && (
      <section class="card-base p-4 onload-animation" style="animation-delay: 250ms">
        <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
          <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">archive</span>
            归档
          </span>
        </h4>
        <ul class="space-y-1.5">
          {archives.map(([month, count]) => (
            <li class="flex items-center justify-between text-sm text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-colors">
              <span>{month}</span>
              <span class="text-xs opacity-60">{count}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</div>
