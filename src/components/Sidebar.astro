---
import type { CollectionEntry } from 'astro:content';
import site from '../site.json';
const SITE = site;

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;

// 按标签统计
const tagMap = new Map<string, number>();
posts.forEach(p => {
  p.data.tags?.forEach(t => {
    tagMap.set(t, (tagMap.get(t) || 0) + 1);
  });
});
const tags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 15);

// 最新文章
const recent = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

// 归档
const archiveMap = new Map<string, number>();
posts.forEach(p => {
  const key = p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
  archiveMap.set(key, (archiveMap.get(key) || 0) + 1);
});
const archives = [...archiveMap.entries()].slice(0, 8);
---
<aside class="space-y-8 text-sm">
  <!-- 搜索 -->
  <section>
    <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
      搜索
    </h4>
    <form action="/search" method="get" class="relative">
      <input
        type="search"
        name="q"
        placeholder="搜索文章..."
        class="w-full pl-9 pr-3 py-2 rounded-lg bg-[rgb(var(--bg-soft))] border border-[rgb(var(--border))]/50 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--fg-soft))] focus:outline-none focus:border-[rgb(var(--primary))] focus:ring-1 focus:ring-[rgb(var(--primary))]/30 transition-colors"
      />
      <svg class="absolute left-3 top-2.5 w-4 h-4 text-[rgb(var(--fg-soft))]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <path d="M21 21l-4.35-4.35"/>
      </svg>
    </form>
  </section>

  <!-- 标签云 -->
  {tags.length > 0 && (
    <section>
      <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
        标签
      </h4>
      <div class="flex flex-wrap gap-1.5">
        {tags.map(([tag, count]) => (
          <a href={`/tags/${tag}`} class="tag-chip">
            #{tag} <span class="opacity-50 ml-0.5">{count}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- 最新文章 -->
  {recent.length > 0 && (
    <section>
      <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
        最新
      </h4>
      <ul class="space-y-3">
        {recent.map(p => (
          <li>
            <a
              href={`/posts/${p.slug}/`}
              class="block group"
            >
              <div class="text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors font-medium line-clamp-2 leading-snug">
                {p.data.title}
              </div>
              <div class="flex items-center gap-2 mt-0.5 text-xs text-[rgb(var(--fg-soft))]">
                <span>{p.data.date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}</span>
                {p.data.tags && p.data.tags.length > 0 && (
                  <span class="flex gap-1 flex-wrap">
                    {p.data.tags.slice(0, 2).map(t => (
                      <span class="opacity-60">#{t}</span>
                    ))}
                  </span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- 归档 -->
  {archives.length > 0 && (
    <section>
      <h4 class="text-xs font-semibold text-[rgb(var(--fg-soft))] uppercase tracking-wider mb-3">
        归档
      </h4>
      <ul class="space-y-1.5">
        {archives.map(([month, count]) => (
          <li class="flex items-center justify-between text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-colors duration-200">
            <span>{month}</span>
            <span class="text-xs opacity-60">{count}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- RSS -->
  <section>
    <a
      href="/rss.xml"
      class="flex items-center gap-2 text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-colors"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 11a9 9 0 0 1 9 9"/>
        <path d="M4 4a16 16 0 0 1 16 16"/>
        <circle cx="5" cy="19" r="1"/>
      </svg>
      <span>RSS 订阅</span>
    </a>
  </section>
</aside>
