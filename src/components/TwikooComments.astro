---
// Twikoo 评论组件
// 用法：<TwikooComments /> 放在任何想要展示评论的地方

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<!-- 配置仅在首次注入时设置，防止 SPA 导航重复定义 -->
<script is:inline>
  if (!window.__TWIKOO_CONFIG__) {
    window.__TWIKOO_CONFIG__ = {
      "enabled": true,
      "envId": "https://twikoo.260607.best",
      "lang": "zh-CN"
    };
  }
</script>

<div id="tcomment" class={className}></div>

<script is:inline>
  (function () {
    // 防止重复初始化
    if (window.__twikoo_loaded__) return;

    function loadTwikoo() {
      // 动态加载 twikoo，避免静态 script 带来的变量冲突
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.7.11/dist/twikoo.min.js';
      s.onload = function () {
        var config = window.__TWIKOO_CONFIG__ || {
          envId: 'https://your-twikoo.vercel.app',
          lang: 'zh-CN',
          sort: 'desc',
          emoticon: [
            'https://cdn.jsdelivr.net/gh/qcm/qq_emoji@master/dist/qq_emoji/all.gif'
          ]
        };
        if (typeof twikoo !== 'undefined') {
          twikoo.init({
            el: '#tcomment',
            ...config
          });
          window.__twikoo_loaded__ = true;
        }
      };
      document.head.appendChild(s);
    }
    loadTwikoo();

    // 监听主题切换，同步更新 Twikoo 主题
    function updateTwikooTheme() {
      if (typeof twikoo === 'undefined') return;
      var theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      try {
        twikoo.setDarkMode(theme);
      } catch (e) {
        // twikoo 可能还没完全初始化，忽略
      }
    }
    document.getElementById('theme-toggle')?.addEventListener('click', function () {
      setTimeout(updateTwikooTheme, 100);
    });
  })();
</script>
