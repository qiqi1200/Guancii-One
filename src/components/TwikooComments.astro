---
// Twikoo 评论组件
// 用法：<TwikooComments /> 放在任何想要展示评论的地方

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<!-- 配置仅在首次注入时设置，防止 SPA 导航重复定义 -->
<script is:inline>
  if (!window.__TWIKOO_CONFIG__) {
    window.__TWIKOO_CONFIG__ = {
      "enabled": true,
      "envId": "https://twikoo.260607.best",
      "lang": "zh-CN"
    };
  }
</script>

<div id="tcomment" class={className}></div>

<script is:inline>
  (function () {
    // 防止重复初始化
    if (window.__twikoo_loaded__) return;

    function loadTwikoo() {
      var src = 'https://cdn.jsdelivr.net/npm/twikoo@1.7.13/dist/twikoo.min.js';

      function runTwikoo() {
        var config = window.__TWIKOO_CONFIG__ || {
          envId: 'https://your-twikoo.vercel.app',
          lang: 'zh-CN',
          sort: 'desc',
          emoticon: [
            'https://cdn.jsdelivr.net/gh/qcm/qq_emoji@master/dist/qq_emoji/all.gif'
          ]
        };
        if (typeof twikoo !== 'undefined') {
          twikoo.init({
            el: '#tcomment',
            ...config
          });
          window.__twikoo_loaded__ = true;
        }
      }

      // 先抓取脚本内容，替换默认头像 CDN（weavatar.com 已挂），再执行
      fetch(src, { credentials: 'omit' })
        .then(function (r) {
          // 安全检查：拒绝非 JS 响应（防止 CDN 劫持返回 HTML 钓鱼页）
          var ct = r.headers.get('content-type') || '';
          if (!ct.includes('javascript') && !ct.includes('json') && !ct.includes('text/plain')) {
            throw new Error('Unexpected content type: ' + ct);
          }
          return r.text();
        })
        .then(function (code) {
          // 安全检查：拒绝 HTML 响应（防止中间人注入）
          if (/^\s*<!doctype\s*html/i.test(code) || /^\s*<html/i.test(code)) {
            throw new Error('HTML response rejected');
          }
          // 默认头像 CDN 从坏的 weavatar.com 改为 cravatar.cn（国内可用）
          code = code.replace(/weavatar\.com/g, 'cravatar.cn');
          var blob = new Blob([code], { type: 'application/javascript' });
          var url = URL.createObjectURL(blob);
          var s = document.createElement('script');
          s.src = url;
          s.onload = function () {
            URL.revokeObjectURL(url);
            if (s.parentNode) s.parentNode.removeChild(s);
            runTwikoo();
          };
          s.onerror = function () {
            URL.revokeObjectURL(url);
            if (s.parentNode) s.parentNode.removeChild(s);
          };
          document.head.appendChild(s);
        })
        .catch(function () {
          // fetch 失败时降级直接加载原脚本
          var s = document.createElement('script');
          s.src = src;
          s.crossOrigin = 'anonymous';
          s.onload = function () {
            if (s.parentNode) s.parentNode.removeChild(s);
            runTwikoo();
          };
          s.onerror = function () {
            if (s.parentNode) s.parentNode.removeChild(s);
          };
          document.head.appendChild(s);
        });
    }
    loadTwikoo();

    // 监听主题切换，同步更新 Twikoo 主题
    function updateTwikooTheme() {
      if (typeof twikoo === 'undefined') return;
      var theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      try {
        twikoo.setDarkMode(theme);
      } catch (e) {
        // twikoo 可能还没完全初始化，忽略
      }
    }
    document.getElementById('theme-toggle')?.addEventListener('click', function () {
      setTimeout(updateTwikooTheme, 100);
    });
  })();
</script>
