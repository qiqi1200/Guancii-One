---
import site from '../site.json';
const SITE = site;
const year = new Date().getFullYear();
---
<footer class="mt-16 md:mt-24 border-t border-dashed border-[rgb(var(--border))]/40 bg-[rgb(var(--bg-soft))]/30 transition-colors">
  <div class="max-w-6xl mx-auto px-6 py-8 md:py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 md:gap-8 text-sm font-body">
      <div class="sm:col-span-2 md:col-span-1">
        <div class="font-handwritten text-lg text-[rgb(var(--secondary))] mb-2">
          {SITE.title}
        </div>
        <p class="text-[rgb(var(--fg-soft))] leading-relaxed font-body text-sm">
          {SITE.description}
        </p>
      </div>

      <div>
        <div class="font-label text-xs uppercase tracking-widest text-[rgb(var(--fg-soft))] mb-3">链接</div>
        <ul class="space-y-2 text-[rgb(var(--fg))]">
          <li><a href="/about" class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-block">关于我</a></li>
          <li><a href="/archive" class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-block">归档</a></li>
          <li><a href="/tags" class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-block">标签</a></li>
          <li><a href="/rss.xml" class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-block">RSS</a></li>
        </ul>
      </div>

      <div>
        <div class="font-label text-xs uppercase tracking-widest text-[rgb(var(--fg-soft))] mb-3">联系</div>
        <ul class="space-y-2 text-[rgb(var(--fg))]">
          <li>
            <a href={SITE.links.github} class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-flex items-center gap-1.5" target="_blank" rel="noopener">
              <span class="material-symbols-outlined text-base">code</span>
              GitHub
            </a>
          </li>
          <li>
            <a href={SITE.links.email} class="hover:text-[rgb(var(--primary))] transition-all ios-press inline-flex items-center gap-1.5">
              <span class="material-symbols-outlined text-base">mail</span>
              邮箱
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-6 md:mt-8 pt-5 md:pt-6 border-t border-dashed border-[rgb(var(--border))]/40 text-xs text-[rgb(var(--fg-soft))] flex flex-col sm:flex-row justify-between gap-2 font-body items-center">
      <div>© {year} {SITE.author}</div>
      <div id="site-runtime" class="font-mono text-[rgb(var(--primary))]"></div>
      <div>Built with <span class="text-[rgb(var(--primary))]">Astro</span> · <span class="text-[rgb(var(--secondary))]">Tailwind</span></div>
    </div>
  </div>
</footer>

<script is:inline>
(function() {
  // 网站运行时间 —— 从 2026 年 6 月 12 日 00:00:00 (UTC+8) 开始计
  const start = new Date('2026-06-12T00:00:00+08:00');
  const el = document.getElementById('site-runtime');

  function pad(n) { return String(n).padStart(2, '0'); }

  function update() {
    const diff = Math.floor((Date.now() - start.getTime()) / 1000);
    if (diff < 0) { el.textContent = '还没开始运行'; return; }

    const days = Math.floor(diff / 86400);
    const rem = diff % 86400;
    const hours = Math.floor(rem / 3600);
    const mins = Math.floor((rem % 3600) / 60);
    const secs = rem % 60;

    el.textContent = `✱ 已运行 ${days} 天 ${pad(hours)}:${pad(mins)}:${pad(secs)}`;
  }

  update();
  setInterval(update, 1000);
})();
</script>
