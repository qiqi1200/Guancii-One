---
import site from '../site.json';
const SITE = site;
const { current = '' } = Astro.props;
const navItems = [
  { href: '/', label: '首页', key: 'home' },
  { href: '/about', label: '关于', key: 'about' },
  { href: '/archive', label: '归档', key: 'archive' },
  { href: '/tags', label: '标签', key: 'tags' }
];
const path = current || Astro.url.pathname;
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-cream-50/80 dark:bg-ink-700/80 border-b border-cream-200 dark:border-ink-600 transition-colors">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-accent-sky to-accent-mint flex items-center justify-center text-cream-50 font-semibold shadow-sm group-hover:shadow-md transition-shadow">
        g
      </div>
      <span class="font-semibold text-ink-700 dark:text-cream-50 tracking-tight">
        {SITE.shortTitle}
      </span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
            path === item.href || (item.href !== '/' && path.startsWith(item.href))
              ? 'text-ink-700 dark:text-cream-50 bg-cream-100 dark:bg-ink-600'
              : 'text-ink-500 dark:text-cream-300 hover:text-ink-700 dark:hover:text-cream-50 hover:bg-cream-100 dark:hover:bg-ink-600'
          }`}
        >
          {item.label}
        </a>
      ))}

      <button
        id="theme-toggle"
        aria-label="切换主题"
        class="ml-2 p-2 rounded-lg text-ink-500 dark:text-cream-300 hover:text-ink-700 dark:hover:text-cream-50 hover:bg-cream-100 dark:hover:bg-ink-600 transition-colors"
      >
        <svg class="w-4 h-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="w-4 h-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  // 主题切换
  const themeToggle = document.getElementById('theme-toggle');
  const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
    document.documentElement.classList.add('dark');
  }
  themeToggle?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem(
      'theme',
      document.documentElement.classList.contains('dark') ? 'dark' : 'light'
    );
  });
</script>
