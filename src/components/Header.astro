---
import site from '../site.json';
const SITE = site;
const { current = '' } = Astro.props;
const navItems = [
  { href: '/', label: '首页', key: 'home' },
  { href: '/about', label: '关于', key: 'about' },
  { href: '/archive', label: '归档', key: 'archive' },
  { href: '/tags', label: '标签', key: 'tags' }
];
const path = current || Astro.url.pathname;
---

<div id="navbar" class="z-50 onload-animation">
  <div class="card-base !overflow-visible max-w-[var(--page-width,72rem)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4">
    <a href="/" class="flex items-center gap-3 rounded-2xl h-[3.25rem] px-4 hover:bg-[rgb(var(--primary-light)/0.08)] transition-all ios-press">
      <img
        src={SITE.avatar}
        alt={SITE.author}
        class="w-8 h-8 rounded-full object-cover shadow-sm"
      />
      <span class="font-headline font-bold tracking-tight text-base text-[rgb(var(--fg))]">
        {SITE.shortTitle}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => {
        const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`rounded-2xl h-11 font-bold px-5 transition-all ios-press flex items-center ${
              active
                ? 'text-[rgb(var(--primary))] bg-[rgb(var(--primary-light)/0.1)]'
                : 'text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.05)]'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-1">
      <!-- 搜索 -->
      <a href="/search"
        class="btn-plain rounded-2xl h-11 w-11 flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.08)] transition-all ios-press-light"
        aria-label="搜索"
      >
        <span class="material-symbols-outlined text-xl">search</span>
      </a>

      <!-- 主题切换 -->
      <button
        id="theme-toggle"
        aria-label="切换主题"
        class="rounded-2xl h-11 w-11 flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.08)] transition-all ios-press-light relative"
      >
        <span class="material-symbols-outlined absolute text-xl transition-all duration-400 dark:rotate-90 dark:opacity-0 rotate-0 opacity-100">light_mode</span>
        <span class="material-symbols-outlined absolute text-xl transition-all duration-400 dark:rotate-0 dark:opacity-100 rotate-90 opacity-0">dark_mode</span>
      </button>

      <!-- 移动端菜单 -->
      <button
        id="nav-menu-switch"
        aria-label="菜单"
        aria-expanded="false"
        aria-controls="nav-menu-panel"
        class="rounded-2xl w-11 h-11 flex items-center justify-center text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.08)] transition-all ios-press-light md:hidden"
      >
        <span class="material-symbols-outlined text-xl">menu</span>
      </button>
    </div>
  </div>
</div>

<!-- 移动端导航面板 -->
<div id="nav-menu-panel" class="float-panel-closed fixed inset-0 z-40 md:hidden">
  <div class="absolute inset-0 bg-black/30 backdrop-blur-sm" id="nav-menu-overlay" style="pointer-events: none;"></div>
  <div class="absolute right-4 top-20 w-56 card-base rounded-2xl p-3 shadow-xl">
    <nav class="flex flex-col gap-1">
      {navItems.map(item => {
        const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`block px-4 py-3 rounded-2xl text-sm font-bold transition-all ios-press ${
              active
                ? 'text-[rgb(var(--primary))] bg-[rgb(var(--primary-light)/0.1)]'
                : 'text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:bg-[rgb(var(--primary-light)/0.05)]'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</div>

<script is:inline>
  // 主题切换（带圆形揭示动画）
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', (e) => {
    const isDark = document.documentElement.classList.contains('dark');

    // 切换主题的核心逻辑
    function applyTheme() {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem(
        'theme',
        document.documentElement.classList.contains('dark') ? 'dark' : 'light'
      );
    }

    // 如果浏览器不支持 View Transition API 或用户偏好减少动画，直接切换
    if (!document.startViewTransition || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      applyTheme();
      return;
    }

    // 计算动画起始点（按钮中心）
    const rect = themeToggle.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    // 计算覆盖整个视口所需的最大半径
    const endRadius = Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y)
    );

    const transition = document.startViewTransition(applyTheme);

    // 设置动画：从按钮中心向外扩散的圆形
    transition.ready.then(() => {
      const clipPath = [
        `circle(0px at ${x}px ${y}px)`,
        `circle(${endRadius}px at ${x}px ${y}px)`
      ];

      document.documentElement.animate(
        {
          clipPath: isDark ? clipPath : [...clipPath].reverse()
        },
        {
          duration: 500,
          easing: 'cubic-bezier(0.23, 1, 0.32, 1)',
          pseudoElement: isDark
            ? '::view-transition-new(root)'
            : '::view-transition-old(root)'
        }
      );
    });
  });

  // 移动端菜单（兼容桌面 click 与移动端 touch）
  (function() {
    const menuSwitch = document.getElementById('nav-menu-switch');
    const menuPanel = document.getElementById('nav-menu-panel');
    if (!menuSwitch || !menuPanel) return;

    let navigating = false;

    function openMenu() {
      menuPanel.classList.remove('float-panel-closed');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menuPanel.classList.add('float-panel-closed');
      document.body.style.overflow = '';
    }

    function toggleMenu() {
      if (menuPanel.classList.contains('float-panel-closed')) {
        openMenu();
      } else {
        closeMenu();
      }
    }

    // 导航到目标页面
    function navigateTo(link) {
      if (!link || navigating) return;
      const href = link.getAttribute('href');
      if (!href || href.startsWith('#')) return;

      if (window.location.pathname === href) {
        closeMenu();
        return;
      }

      navigating = true;
      closeMenu();
      window.location.href = href;
    }

    // 事件委托：菜单项点击/触摸 → 导航；空白区域 → 关菜单
    function handlePanelActivate(e) {
      const link = e.target.closest('#nav-menu-panel a[href]');
      if (link) {
        e.stopPropagation();
        e.preventDefault();
        navigateTo(link);
      } else {
        closeMenu();
      }
    }

    // 开关按钮
    function handleSwitch(e) {
      e.stopPropagation();
      toggleMenu();
    }

    menuSwitch.addEventListener('click', handleSwitch);
    menuSwitch.addEventListener('touchend', handleSwitch);

    menuPanel.addEventListener('click', handlePanelActivate);
    menuPanel.addEventListener('touchend', handlePanelActivate, { passive: false });

    // 键盘 ESC 关闭
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !menuPanel.classList.contains('float-panel-closed')) {
        closeMenu();
      }
    });
  })();
</script>
