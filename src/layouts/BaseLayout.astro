---
import site from '../site.json';
const SITE = site;
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  current?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = '/og-default.png',
  current
} = Astro.props;

const fullTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />

    <!-- 字体注入：Montserrat + 手写体 Architects Daughter + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&family=Architects+Daughter&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <!-- medium-zoom：文章图片点击放大 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/medium-zoom@1.1.0/dist/medium-zoom.min.css" />

    <!-- 主题预检脚本（默认浅色，用户可手动切换） -->
    <script is:inline>
      (function() {
        // 始终从浅色开始，忽略 localStorage 中的 dark 偏好
        localStorage.setItem('theme', 'light');
        document.documentElement.classList.remove('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[rgb(var(--bg))] text-[rgb(var(--fg))] transition-colors">
    <!-- 鼠标光晕 -->
    <div class="cursor-blob" id="cursor-blob"></div>

    <Header current={current} />

    <main class="flex-1 w-full relative z-10">
      <slot />
    </main>

    <Footer />

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      aria-label="返回顶部"
      class="no-print fixed bottom-6 right-6 w-12 h-12 rounded-full bg-[rgb(var(--primary-light))] text-[rgb(var(--fg-on-primary))] shadow-lg hover:shadow-[0_0_20px_rgba(255,182,147,0.5)] hover:-translate-y-0.5 transition-all opacity-0 pointer-events-none z-30 flex items-center justify-center"
    >
      <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <script is:inline>
      // 返回顶部按钮
      const backBtn = document.getElementById('back-to-top');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 600) {
          backBtn?.classList.remove('opacity-0', 'pointer-events-none');
          backBtn?.classList.add('opacity-100');
        } else {
          backBtn?.classList.add('opacity-0', 'pointer-events-none');
          backBtn?.classList.remove('opacity-100');
        }
      });
      backBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // 鼠标光晕（仅在非触控设备上启用）
      const blob = document.getElementById('cursor-blob');
      const isTouch = window.matchMedia('(hover: none)').matches;
      if (blob && !isTouch) {
        document.addEventListener('mousemove', (e) => {
          blob.style.left = `${e.clientX}px`;
          blob.style.top = `${e.clientY}px`;
        });
      } else if (blob) {
        blob.style.display = 'none';
      }

      // 卡片微动效（轻量）
      document.querySelectorAll('.magnetic-hover').forEach(item => {
        item.addEventListener('mouseenter', () => {
          item.style.transform = 'scale(1.008)';
        });
        item.addEventListener('mouseleave', () => {
          item.style.transform = '';
        });
      });
    </script>
  </body>
</html>
