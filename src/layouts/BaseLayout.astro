---
import site from '../site.json';
const SITE = site;
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  current?: string;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.avatar,
  current
} = Astro.props;

const fullTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon（多尺寸适配） -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />

    <!-- 资源预连接（加速第三方资源加载） -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://pic.224418.xyz" />

    <!-- 预加载深浅模式背景图 -->
    <link rel="preload" as="image" href="https://pic.224418.xyz/file/archive/pic/1784819551828_bdad1114d2a2802d718351066ed154e4.jpg" />
    <link rel="preload" as="image" href="https://pic.224418.xyz/file/archive/pic/1784819713707_a9cdc5e92737e00b5d10535f43a06be3.jpg" />

    <!-- 字体：Montserrat + 手写体 Architects Daughter + Material Symbols -->
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&family=Architects+Daughter&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
      rel="stylesheet"
    />

    <!-- FancyBox：文章图片点击放大 + 图库导航 -->
    <link rel="stylesheet" href="/fancybox/fancybox.css" />

    <!-- 主题预检脚本（默认浅色，尊重用户已保存的偏好） -->
    <script is:inline>
      (function() {
        // 读取用户保存的主题偏好，如无则默认浅色
        var saved = localStorage.getItem('theme');
        if (saved === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        }
      })();
    </script>

    <!-- 51.la 访问统计 -->
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" async></script>
    <script>LA.init({id:"3QTlGG2A1JijpoBK",ck:"3QTlGG2A1JijpoBK"})</script>
  </head>
  <body class="min-h-screen flex flex-col bg-[rgb(var(--bg))] text-[rgb(var(--fg))] transition-colors">
    <!-- 背景图片层（全屏、固定、下层） -->
    <div id="bg-layer" aria-hidden="true">
      <img id="bg-light" src="https://pic.224418.xyz/file/archive/pic/1784819551828_bdad1114d2a2802d718351066ed154e4.jpg" alt="" />
      <img id="bg-dark" src="https://pic.224418.xyz/file/archive/pic/1784819713707_a9cdc5e92737e00b5d10535f43a06be3.jpg" alt="" />
      <div id="bg-overlay"></div>
    </div>
    <!-- 鼠标光晕 -->
    <div class="cursor-blob" id="cursor-blob"></div>

    <!-- TOP ROW: Navbar -->
    <div id="top-row" class="z-50 pointer-events-none relative max-w-[var(--page-width,72rem)] px-4 md:px-0 mx-auto">
      <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all z-50">
        <Header current={current} />
      </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="w-full z-30 pointer-events-none">
      <div class="relative max-w-[var(--page-width,72rem)] mx-auto pointer-events-auto">
        <div id="main-grid" class="w-full left-0 right-0 grid grid-cols-1 lg:grid-cols-[260px_1fr] mx-auto gap-8 px-6 md:px-6">

          <!-- Sidebar (left, second row on mobile, first column on desktop) -->
          <div class="mb-4 row-start-2 lg:row-start-1 lg:col-span-1 onload-animation">
            <slot name="sidebar" />
          </div>

          <!-- Main content (right, first on mobile, second column on desktop) -->
          <main class="col-span-1 lg:col-span-1 overflow-hidden" id="swup-container">
            <div id="content-wrapper" class="page-entrance onload-animation">
              <slot />
            </div>
          </main>

        </div>
      </div>
    </div>

    <!-- Footer -->
    <Footer />

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      aria-label="返回顶部"
      class="no-print fixed bottom-6 right-6 w-12 h-12 rounded-full bg-[rgb(var(--primary-light))] text-[rgb(var(--fg-on-primary))] shadow-lg hover:shadow-[0_0_20px_rgba(255,182,147,0.5)] hover:-translate-y-0.5 transition-all duration-300 opacity-0 pointer-events-none z-30 flex items-center justify-center"
    >
      <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <script is:inline>
      // 返回顶部按钮（带节流）
      const backBtn = document.getElementById('back-to-top');
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            if (window.scrollY > 600) {
              backBtn?.classList.remove('opacity-0', 'pointer-events-none');
              backBtn?.classList.add('opacity-100');
            } else {
              backBtn?.classList.add('opacity-0', 'pointer-events-none');
              backBtn?.classList.remove('opacity-100');
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
      backBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // 鼠标光晕（仅在非触控设备上启用）
      const blob = document.getElementById('cursor-blob');
      const isTouch = window.matchMedia('(hover: none)').matches;
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (blob && !isTouch && !prefersReduced) {
        document.addEventListener('mousemove', (e) => {
          blob.style.left = `${e.clientX}px`;
          blob.style.top = `${e.clientY}px`;
        });
      } else if (blob) {
        blob.style.display = 'none';
      }

      // 滚动入场动画（IntersectionObserver，仅非 reduced-motion 用户）
      if (!prefersReduced) {
        // iOS 交错入场：.onload-animation 元素在页面加载后依次显现
        const staggerItems = document.querySelectorAll('.onload-animation');
        staggerItems.forEach((el, i) => {
          // 使用 data-stagger 或按索引分配延迟（0ms, 50ms, 100ms... 类似 iOS Spring 序列）
          const delay = parseInt(el.dataset.stagger || '0') || (i * 50);
          setTimeout(() => {
            el.classList.add('is-visible');
          }, delay);
        });

        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('.scroll-reveal').forEach(el => {
          revealObserver.observe(el);
        });
      } else {
        // reduced-motion：直接显示所有
        document.querySelectorAll('.onload-animation, .scroll-reveal').forEach(el => {
          el.classList.add('is-visible');
        });
      }
    </script>
  </body>
</html>

<style>
  :root {
    --content-delay: 0ms;
    --page-width: 72rem;
  }

  /* iOS 风格字号相关 tracking — 大字号收紧，正文放松 */
  h1, h2, h3, h4, h5, h6 {
    letter-spacing: -0.02em;
  }
  body {
    letter-spacing: 0.01em;
  }

  /* 背景图层 — 全屏固定，z-index 在 body 之下 */
  #bg-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
  }
  #bg-layer img {
    position: absolute;
    inset: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    will-change: opacity, transform;
    transition: opacity 1.5s cubic-bezier(0.23, 1, 0.32, 1);
  }
  #bg-light {
    opacity: 1;
    animation: ken-burns-light 30s ease-in-out infinite alternate;
  }
  #bg-dark {
    opacity: 0;
    animation: ken-burns-dark 30s ease-in-out infinite alternate;
  }
  .dark #bg-light {
    opacity: 0;
  }
  .dark #bg-dark {
    opacity: 1;
  }
  /* 缓慢肯尼兹缩放 — 画面始终在微运动，切换时人眼不易察觉内容错位 */
  @keyframes ken-burns-light {
    0%   { transform: scale(1) translate(0, 0); }
    50%  { transform: scale(1.04) translate(-1%, 0.5%); }
    100% { transform: scale(1) translate(0, 0); }
  }
  @keyframes ken-burns-dark {
    0%   { transform: scale(1) translate(0, 0); }
    50%  { transform: scale(1.04) translate(-1%, 0.5%); }
    100% { transform: scale(1) translate(0, 0); }
  }
  /* 半透明遮罩 — 保证文字始终可读 */
  #bg-overlay {
    position: absolute;
    inset: 0;
    background: rgb(var(--bg) / 0.62);
    transition: background 1.2s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .dark #bg-overlay {
    background: rgb(17 19 28 / 0.66);
  }

  /* 缩短上滑距离，加快入场，更 iOS */
  .page-entrance {
    animation: page-entrance 350ms var(--ease-smooth) both;
  }
  @keyframes page-entrance {
    0% {
      opacity: 0;
      transform: translateY(8px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
