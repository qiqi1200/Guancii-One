---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import site from '../site.json';
const SITE = site;

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = posts[0];
const rest = posts.slice(1);

// 收集所有标签
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---
<BaseLayout title="首页" current="/">
  <!-- Hero 区（UniVibe 涂鸦风格） -->
  <section class="relative pt-24 pb-12 md:pt-32 md:pb-16 px-6 max-w-6xl mx-auto animate-fade-in overflow-hidden">
    <!-- 装饰光晕 -->
    <div class="absolute -top-20 -right-20 w-80 h-80 opacity-30 rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(var(--primary-light), 0.2), transparent 70%);"></div>
    <div class="absolute -bottom-20 -left-20 w-60 h-60 opacity-20 rounded-full blur-3xl pointer-events-none"
         style="background: radial-gradient(circle, rgba(var(--secondary), 0.15), transparent 70%);"></div>

    <div class="relative z-10">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-12">
        <!-- 头像 -->
        <div class="relative group flex-shrink-0 mx-auto md:mx-0">
          <div class="relative w-28 h-28 md:w-36 md:h-36 rounded-full p-0.5 shadow-md transition-shadow duration-300"
               style="background: linear-gradient(135deg, rgb(var(--primary-light)), rgb(var(--secondary)), rgb(var(--tertiary)));">
            <img
              src={SITE.avatar}
              alt={SITE.author}
              class="w-full h-full rounded-full object-cover bg-[rgb(var(--bg))]"
            />
          </div>
        </div>

        <div class="text-center md:text-left">
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-bold tracking-tight text-[rgb(var(--fg))] leading-tight">
            你好，我是 <span class="doodle-underline text-[rgb(var(--primary))]">{SITE.author}</span>
          </h1>
          <p class="mt-4 text-base md:text-lg text-[rgb(var(--fg-soft))] leading-relaxed max-w-2xl font-handwritten">
            来自吉林四平，在天津的中国民航大学读交通工程，大一。
            记点生活里的小事、读过的书、学过的东西。
            这里没什么宏大叙事，就是一些安静的思考和日常。
          </p>
          <div class="mt-8 flex flex-wrap gap-3 justify-center md:justify-start">
            <a href="/about" class="px-6 py-2.5 rounded-full bg-[rgb(var(--primary-light))] text-[rgb(var(--fg-on-primary))] font-label text-sm font-bold transition-all hover:shadow-[0_0_12px_rgba(var(--primary-light),0.3)]">
              <span class="material-symbols-outlined text-base align-middle mr-1">person</span>
              了解我
            </a>
            <a href="/archive" class="px-6 py-2.5 rounded-full border border-[rgb(var(--outline-variant))] hover:bg-[rgb(var(--surface-variant))]/30 font-label text-sm transition-all font-handwritten text-[rgb(var(--secondary))]">
              <span class="material-symbols-outlined text-base align-middle mr-1">auto_stories</span>
              浏览归档
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 标签筛选（液态玻璃） -->
  {allTags.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 mb-8">
      <div class="liquid-glass rounded-2xl p-4">
        <div class="flex flex-wrap gap-2">
          <button data-tag="all" class="tag-chip tag-filter active font-label">
            <span class="material-symbols-outlined text-xs mr-1">apps</span>
            全部
          </button>
          {allTags.map(tag => (
            <button data-tag={tag} class="tag-chip tag-filter font-label">
              #{tag}
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 文章网格 + 侧边栏 -->
  <section class="max-w-6xl mx-auto px-6 pb-16">
    <div class="grid lg:grid-cols-[1fr_280px] gap-12">
      <div>
        <h2 class="text-2xl md:text-headline-md font-headline font-semibold text-[rgb(var(--fg))] mb-8 flex items-center gap-2">
          <span class="w-1.5 h-6 rounded-full"
                style="background: linear-gradient(to bottom, rgb(var(--primary)), rgb(var(--secondary)));"></span>
          最新文章
        </h2>

        {featured && (
          <div class="mb-8">
            <PostCard post={featured} featured={true} />
          </div>
        )}

        <div class="grid sm:grid-cols-2 gap-6 post-grid">
          {rest.map(p => (
            <div data-tags={JSON.stringify(p.data.tags || [])}>
              <PostCard post={p} />
            </div>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="text-center py-20 text-[rgb(var(--fg-soft))] font-body">
            <span class="material-symbols-outlined text-6xl mb-4 block opacity-40">edit_note</span>
            还没有文章，先去写下第一篇吧 ✍️
          </div>
        )}
      </div>

      <div class="hidden lg:block">
        <div class="sticky top-24">
          <Sidebar posts={posts} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // 标签筛选
  const filterBtns = document.querySelectorAll('.tag-filter');
  const postCards = document.querySelectorAll('.post-grid > div');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      postCards.forEach(card => {
        const tags = JSON.parse(card.getAttribute('data-tags') || '[]');
        card.style.display = (tag === 'all' || tags.includes(tag)) ? '' : 'none';
      });
    });
  });
</script>
