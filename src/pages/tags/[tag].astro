---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const postsList = (await getCollection('posts')).filter(p => !p.data.draft);
  const tags = [...new Set(postsList.flatMap(p => p.data.tags || []))];
  return tags.map(t => ({
    params: { tag: t },
    props: { allPosts: postsList, posts: postsList.filter(p => p.data.tags?.includes(t)) }
  }));
}

const { tag } = Astro.params;
const { posts, allPosts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`关于 ${tag} 的所有文章`}>
  <div slot="sidebar">
    <Sidebar posts={allPosts} />
  </div>

  <article class="pb-8 onload-animation">
    <header class="mb-8">
      <a href="/tags" class="text-sm text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-colors inline-flex items-center gap-1">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        返回所有标签
      </a>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-[rgb(var(--fg))] mt-4">
        #<span class="text-[rgb(var(--primary))]">{tag}</span>
      </h1>
      <p class="mt-4 text-[rgb(var(--fg-soft))]">
        共 {posts.length} 篇
      </p>
    </header>

    <div class="grid sm:grid-cols-2 gap-4">
      {posts
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map(p => <PostCard post={p} />)
      }
    </div>
  </article>
</BaseLayout>
