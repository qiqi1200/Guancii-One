---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = [...new Set(posts.flatMap(p => p.data.tags || []))];
  return tags.map(tag => ({
    params: { tag },
    props: { posts: posts.filter(p => p.data.tags?.includes(tag)) }
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---
<BaseLayout title={`#${tag}`} description={`关于 ${tag} 的所有文章`}>
  <article class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-12 animate-fade-in">
      <a href="/tags" class="text-sm text-ink-400 dark:text-cream-300 hover:text-accent-sky transition-colors">
        ← 返回所有标签
      </a>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink-700 dark:text-cream-50 mt-4">
        #<span class="text-accent-sky">{tag}</span>
      </h1>
      <p class="mt-4 text-ink-500 dark:text-cream-300">
        共 {posts.length} 篇
      </p>
    </header>

    <div class="grid sm:grid-cols-2 gap-6">
      {posts
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
        .map(p => <PostCard post={p} />)
      }
    </div>
  </article>
</BaseLayout>
