---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [...new Set(posts.flatMap(p => p.data.tags || []))];

// 按标签统计数量
const tagCounts = new Map<string, number>();
posts.forEach(p => {
  p.data.tags?.forEach(t => {
    tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
  });
});
const allPosts = posts;
---

<BaseLayout title="标签" current="/tags">
  <div slot="sidebar">
    <Sidebar posts={allPosts} />
  </div>

  <article class="pb-8 onload-animation">
    <header class="mb-8">
      <div class="text-sm text-[rgb(var(--fg-soft))] mb-2">标签</div>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-[rgb(var(--fg))]">
        所有标签
      </h1>
      <p class="mt-4 text-[rgb(var(--fg-soft))]">
        共 {tags.length} 个标签 · {posts.length} 篇文章
      </p>
    </header>

    <div class="flex flex-wrap gap-3">
      {tags.map(tag => {
        const count = tagCounts.get(tag) || 0;
        const maxCount = Math.max(...tagCounts.values());
        const minSize = 0.8;
        const maxSize = 2.0;
        const ratio = count / maxCount;
        const fontSize = `${(minSize + (maxSize - minSize) * ratio).toFixed(2)}rem`;
        return (
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-[rgb(var(--border))]/50
                   text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:border-[rgb(var(--primary))]/30
                   transition-all hover:-translate-y-0.5"
            style={`font-size: ${fontSize};`}
          >
            #{tag}
            <span class="text-xs opacity-50">{count}</span>
          </a>
        );
      })}
    </div>
  </article>
</BaseLayout>
