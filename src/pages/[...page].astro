---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import site from '../site.json';
const SITE = site;

export async function getStaticPaths({ paginate }) {
  const all = (await getCollection('posts'))
    .filter(p => !p.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return paginate(all, { pageSize: 8 });
}

const { page } = Astro.props;
const posts = page.data;

// Featured 文章仅在第 1 页显示
const featured = page.currentPage === 1 ? posts[0] : null;
const rest = page.currentPage === 1 ? posts.slice(1) : posts;

// 收集所有标签（从全部文章，非仅当前页）
const allPosts = (await getCollection('posts')).filter(p => !p.data.draft);
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags || []))];

const pageTitle = page.currentPage > 1 ? `首页 · 第 ${page.currentPage} 页` : '首页';
const isFirstPage = page.currentPage === 1;

function pageUrl(n: number): string {
  return n === 1 ? '/' : `/${n}`;
}
---
<BaseLayout title={pageTitle} current="/">
  <!-- Hero 区（仅第 1 页显示） -->
  {isFirstPage && (
    <section class="relative pt-20 pb-8 md:pt-32 md:pb-12 px-6 max-w-6xl mx-auto animate-fade-in overflow-hidden">
      <!-- 装饰光晕 -->
      <div class="absolute -top-20 -right-20 w-80 h-80 opacity-30 rounded-full blur-3xl pointer-events-none"
           style="background: radial-gradient(circle, rgba(var(--primary-light), 0.2), transparent 70%);"></div>
      <div class="absolute -bottom-20 -left-20 w-60 h-60 opacity-20 rounded-full blur-3xl pointer-events-none"
           style="background: radial-gradient(circle, rgba(var(--secondary), 0.15), transparent 70%);"></div>

      <div class="relative z-10">
        <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-12">
          <!-- 头像 -->
          <div class="relative group flex-shrink-0 mx-auto md:mx-0">
            <div class="relative w-24 h-24 md:w-36 md:h-36 rounded-full p-0.5 shadow-md transition-shadow duration-300"
                 style="background: linear-gradient(135deg, rgb(var(--primary-light)), rgb(var(--secondary)), rgb(var(--tertiary)));">
              <img
                src={SITE.avatar}
                alt={SITE.author}
                class="w-full h-full rounded-full object-cover bg-[rgb(var(--bg))]"
              />
            </div>
          </div>

          <div class="text-center md:text-left">
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-bold tracking-tight text-[rgb(var(--fg))] leading-tight">
              你好，我是 <span class="doodle-underline text-[rgb(var(--primary))]">{SITE.author}</span>
            </h1>
            <p class="mt-3 md:mt-4 text-base md:text-lg text-[rgb(var(--fg-soft))] leading-relaxed max-w-2xl font-handwritten">
              来自吉林四平，在天津的中国民航大学读交通工程，大一。
              记点生活里的小事、读过的书、学过的东西。
              这里没什么宏大叙事，就是一些安静的思考和日常。
            </p>
            <div class="mt-6 md:mt-8 flex flex-wrap gap-3 justify-center md:justify-start">
              <a href="/about"
                 class="px-5 py-2 md:px-6 md:py-2.5 rounded-full bg-[rgb(var(--primary-light))] text-[rgb(var(--fg-on-primary))] font-label text-sm font-bold transition-all hover:shadow-[0_0_12px_rgba(var(--primary-light),0.3)]">
                <span class="material-symbols-outlined text-base align-middle mr-1">person</span>
                了解我
              </a>
              <a href="/archive"
                 class="px-5 py-2 md:px-6 md:py-2.5 rounded-full border border-[rgb(var(--outline-variant))] hover:bg-[rgb(var(--surface-variant))]/30 font-label text-sm transition-all font-handwritten text-[rgb(var(--secondary))]">
                <span class="material-symbols-outlined text-base align-middle mr-1">auto_stories</span>
                浏览归档
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 非首页顶部返回 -->
  {!isFirstPage && (
    <section class="pt-24 pb-6 px-6 max-w-6xl mx-auto">
      <a href="/"
         class="inline-flex items-center gap-1 text-sm text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-colors">
        <span class="material-symbols-outlined text-base">arrow_back</span>
        返回首页
      </a>
    </section>
  )}

  <!-- 标签筛选（液态玻璃，仅首页） -->
  {allTags.length > 0 && isFirstPage && (
    <section class="max-w-6xl mx-auto px-6 mb-8">
      <div class="liquid-glass rounded-2xl p-4">
        <div class="flex flex-wrap gap-2 overflow-x-auto scrollbar-none">
          <button data-tag="all" class="tag-chip tag-filter active font-label shrink-0">
            <span class="material-symbols-outlined text-xs mr-1">apps</span>
            全部
          </button>
          {allTags.map(tag => (
            <button data-tag={tag} class="tag-chip tag-filter font-label shrink-0">
              #{tag}
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 文章网格 + 侧边栏 -->
  <section class="max-w-6xl mx-auto px-6 pb-16">
    <div class="grid lg:grid-cols-[1fr_280px] gap-8 md:gap-12">
      <div>
        <h2 class="text-xl md:text-2xl font-headline font-semibold text-[rgb(var(--fg))] mb-6 md:mb-8 flex items-center gap-2">
          <span class="w-1.5 h-6 rounded-full"
                style="background: linear-gradient(to bottom, rgb(var(--primary)), rgb(var(--secondary)));"></span>
          {isFirstPage ? '最新文章' : `第 ${page.currentPage} 页`}
        </h2>

        {featured && (
          <div class="mb-8 post-container scroll-reveal" data-tags={JSON.stringify(featured.data.tags || [])}>
            <PostCard post={featured} featured={true} />
          </div>
        )}

        <!-- 文章网格：列数自适应，剩 1 篇时不启用 2 列 -->
        <div class={`grid gap-6 post-grid ${rest.length > 1 ? 'sm:grid-cols-2' : ''}`}>
          {rest.map((p, i) => (
            <div
              class="post-container scroll-reveal"
              data-tags={JSON.stringify(p.data.tags || [])}
              style={`--delay: ${(i + 1) * 80}ms`}
            >
              <PostCard post={p} />
            </div>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="text-center py-20 text-[rgb(var(--fg-soft))] font-body">
            <span class="material-symbols-outlined text-6xl mb-4 block opacity-40">edit_note</span>
            还没有文章，先去写下第一篇吧 ✍️
          </div>
        )}

        <!-- 分页导航 -->
        {page.lastPage > 1 && (
          <nav class="mt-12 flex items-center justify-center gap-2" aria-label="分页导航">
            {page.currentPage > 1 ? (
              <a href={pageUrl(page.currentPage - 1)}
                 class="px-3 py-1.5 rounded-lg text-sm border border-[rgb(var(--border))]/50 text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:border-[rgb(var(--primary))]/30 transition-colors flex items-center gap-0.5">
                <span class="material-symbols-outlined text-base">chevron_left</span>
                <span class="hidden sm:inline">上一页</span>
              </a>
            ) : (
              <span class="px-3 py-1.5 rounded-lg text-sm border border-[rgb(var(--border))]/20 text-[rgb(var(--fg-soft))]/30 flex items-center gap-0.5 pointer-events-none">
                <span class="material-symbols-outlined text-base">chevron_left</span>
                <span class="hidden sm:inline">上一页</span>
              </span>
            )}

            {Array.from({ length: Math.min(page.lastPage, 7) }, (_, i) => i + 1).map(p => (
              <a href={pageUrl(p)}
                 class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
                   p === page.currentPage
                     ? 'bg-[rgb(var(--primary))] text-[rgb(var(--fg-on-primary))]'
                     : 'border border-[rgb(var(--border))]/50 text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:border-[rgb(var(--primary))]/30'
                 }`}>
                {p}
              </a>
            ))}

            {page.lastPage > 7 && (
              <span class="px-2 text-[rgb(var(--fg-soft))]">...</span>
            )}

            {page.currentPage < page.lastPage ? (
              <a href={pageUrl(page.currentPage + 1)}
                 class="px-3 py-1.5 rounded-lg text-sm border border-[rgb(var(--border))]/50 text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] hover:border-[rgb(var(--primary))]/30 transition-colors flex items-center gap-0.5">
                <span class="hidden sm:inline">下一页</span>
                <span class="material-symbols-outlined text-base">chevron_right</span>
              </a>
            ) : (
              <span class="px-3 py-1.5 rounded-lg text-sm border border-[rgb(var(--border))]/20 text-[rgb(var(--fg-soft))]/30 flex items-center gap-0.5 pointer-events-none">
                <span class="hidden sm:inline">下一页</span>
                <span class="material-symbols-outlined text-base">chevron_right</span>
              </span>
            )}
          </nav>
        )}
      </div>

      <div class="hidden lg:block">
        <div class="sticky top-24">
          <Sidebar posts={allPosts} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // 标签筛选（同时作用于 featured 和普通卡片，带平滑过渡）
  const filterBtns = document.querySelectorAll('.tag-filter');
  const allContainers = document.querySelectorAll('.post-container');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      allContainers.forEach(el => {
        const tags = JSON.parse(el.getAttribute('data-tags') || '[]');
        const match = tag === 'all' || tags.includes(tag);
        if (match) {
          el.classList.remove('hidden-filter');
          el.style.position = '';
          el.style.visibility = '';
        } else {
          el.classList.add('hidden-filter');
        }
      });
    });
  });
</script>
