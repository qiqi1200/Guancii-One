---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 按年月分组
const groups = new Map<string, typeof posts>();
posts.forEach(p => {
  const key = p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(p);
});
---
<BaseLayout title="归档" current="/archive">
  <article class="max-w-3xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-12 animate-fade-in">
      <div class="text-sm text-[rgb(var(--fg-soft))] mb-2">归档</div>
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-[rgb(var(--fg))]">
        全部文章
      </h1>
      <p class="mt-4 text-[rgb(var(--fg-soft))]">
        共 {posts.length} 篇 · 按时间倒序
      </p>
    </header>

    <div class="space-y-12">
      {[...groups.entries()].map(([month, items]) => (
        <section>
          <h2 class="text-lg font-bold text-[rgb(var(--fg))] mb-4 flex items-center gap-2">
            <span class="w-1 h-5 rounded-full bg-[rgb(var(--primary))] inline-block"></span>
            {month}
          </h2>
          <ul class="space-y-3 ml-4 border-l-2 border-[rgb(var(--border))]/30 pl-4">
            {items.map(p => (
              <li>
                <a
                  href={`/posts/${p.slug}/`}
                  class="group flex items-baseline gap-3"
                >
                  <span class="text-xs text-[rgb(var(--fg-soft))] shrink-0 font-body">
                    {String(p.data.date.getDate()).padStart(2, '0')}日
                  </span>
                  <span class="text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors font-body">
                    {p.data.title}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 text-[rgb(var(--fg-soft))]">
        还没有文章。
      </div>
    )}
  </article>
</BaseLayout>
