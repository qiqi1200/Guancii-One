---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const query = Astro.url.searchParams.get('q')?.toLowerCase() || '';
const results = query
  ? allPosts.filter(p =>
      p.data.title.toLowerCase().includes(query) ||
      p.data.description?.toLowerCase().includes(query) ||
      p.data.tags?.some(t => t.toLowerCase().includes(query)) ||
      p.body.toLowerCase().includes(query)
    )
  : [];
---
<BaseLayout title={query ? `搜索: ${query}` : '搜索'}>
  <article class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-12 animate-fade-in">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-[rgb(var(--fg))]">
        搜索
      </h1>
      <form action="/search" method="get" class="mt-6">
        <input
          type="search"
          name="q"
          value={query}
          placeholder="输入关键词..."
          autofocus
          class="w-full max-w-xl px-4 py-3 rounded-lg bg-[rgb(var(--bg-soft))] border border-[rgb(var(--border))]/50 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--fg-soft))] focus:outline-none focus:border-[rgb(var(--primary))] focus:ring-1 focus:ring-[rgb(var(--primary))]/30 transition-colors"
        />
      </form>
    </header>

    {query && (
      <p class="text-[rgb(var(--fg-soft))] mb-8">
        关于「<span class="text-[rgb(var(--primary))] font-medium">{query}</span>」找到 {results.length} 个结果
      </p>
    )}

    {results.length > 0 && (
      <div class="grid sm:grid-cols-2 gap-6">
        {results.map(p => <PostCard post={p} />)}
      </div>
    )}

    {query && results.length === 0 && (
      <p class="text-[rgb(var(--fg-soft))] text-center py-12">
        没有找到相关文章
      </p>
    )}
  </article>
</BaseLayout>
