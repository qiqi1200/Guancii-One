---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';

// 构建搜索索引：提取精简字段供客户端使用
const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const index = allPosts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description || '',
  date: p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }),
  tags: p.data.tags || [],
  cover: p.data.cover || '',
  body: (p.body || '').slice(0, 500) // 只取前 500 字符做索引
}));
---

<BaseLayout title="搜索">
  <div slot="sidebar">
    <Sidebar posts={allPosts} />
  </div>

  <article class="pb-8 onload-animation">
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-headline font-semibold tracking-tight text-[rgb(var(--fg))]">
        搜索
      </h1>
      <form id="search-form" action="/search" method="get" class="mt-6" onsubmit="handleSearch(event)">
        <input
          type="search"
          id="search-input"
          name="q"
          placeholder="输入关键词..."
          autofocus
          class="w-full max-w-xl px-4 py-3 rounded-lg bg-cream-search border border-cream text-cream-heading placeholder:text-cream-soft focus:outline-none focus:border-cream-link focus:ring-1 focus:ring-[#c46010]/20 transition-colors"
        />
      </form>
    </header>

    <p id="search-info" class="text-[rgb(var(--fg-soft))] mb-8 hidden"></p>

    <div id="search-results" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 gap-y-7"></div>

    <p id="search-empty" class="text-[rgb(var(--fg-soft))] text-center py-12 hidden">
      没有找到相关文章
    </p>
  </article>
</BaseLayout>

<!-- 搜索索引：通过 data 属性注入（Astro 对 HTML 属性求值 {Expression}） -->
<div id="search-data" data-index={JSON.stringify(index).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;')} hidden></div>

<script is:inline>
  window.__SEARCH_INDEX__ = JSON.parse(document.getElementById('search-data').dataset.index || '[]');
</script>

<script is:inline>
  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderCard(post) {
    const coverHtml = post.cover
      ? `<div class="card-cream-cover mx-[20px] mt-[20px]">
           <img src="${escapeHtml(post.cover)}" alt="${escapeHtml(post.title)}" loading="lazy">
         </div>`
      : '';

    const tagsHtml = post.tags.length
      ? `<div class="flex flex-wrap gap-1.5 mb-[10px]">
           ${post.tags.slice(0, 4).map(t =>
             `<span class="tag-cream" data-tag="${escapeHtml(t)}">#${escapeHtml(t)}</span>`
           ).join('')}
         </div>`
      : '';

    const dateStr = post.date || '';
    const readTime = Math.max(1, Math.floor((post.body || '').length / 500));

    return `
      <article class="card-cream">
        <a href="/posts/${post.slug}/" class="block h-full flex flex-col">
          ${coverHtml}
          <div class="card-cream-body">
            <div class="flex items-center gap-2 text-xs text-cream-soft mb-[8px]">
              <time datetime="">${escapeHtml(dateStr)}</time>
              <span>·</span>
              <span>${readTime} 分钟</span>
            </div>
            ${tagsHtml}
            <h3 class="font-semibold tracking-tight text-cream-heading text-base leading-snug mb-[10px] line-clamp-2">
              ${escapeHtml(post.title)}
            </h3>
            ${post.description ? `<p class="text-cream-body line-clamp-2 leading-relaxed text-sm mb-[16px]">${escapeHtml(post.description)}</p>` : ''}
            <div class="read-more-link mt-auto pt-1">
              阅读全文
            </div>
          </div>
        </a>
      </article>`;
  }

  function handleSearch(e) {
    e.preventDefault();
    const query = document.getElementById('search-input').value.trim().toLowerCase();
    const infoEl = document.getElementById('search-info');
    const resultsEl = document.getElementById('search-results');
    const emptyEl = document.getElementById('search-empty');

    if (!query) {
      infoEl.classList.add('hidden');
      resultsEl.innerHTML = '';
      emptyEl.classList.add('hidden');
      // 更新 URL 不刷新页面
      history.replaceState(null, '', '/search');
      return;
    }

    // 更新 URL
    history.replaceState(null, '', `/search?q=${encodeURIComponent(query)}`);

    const posts = window.__SEARCH_INDEX__ || [];
    const results = posts.filter(p =>
      p.title.toLowerCase().includes(query) ||
      p.description.toLowerCase().includes(query) ||
      p.tags.some(t => t.toLowerCase().includes(query)) ||
      p.body.toLowerCase().includes(query)
    );

    infoEl.classList.remove('hidden');
    infoEl.innerHTML = `关于「<span class="text-[rgb(var(--primary))] font-medium">${escapeHtml(query)}</span>」找到 ${results.length} 个结果`;

    if (results.length > 0) {
      resultsEl.innerHTML = results.map(renderCard).join('');
      emptyEl.classList.add('hidden');
    } else {
      resultsEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
    }
  }

  // 页面加载时读取 URL 中的查询参数并执行搜索
  (function () {
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q) {
      document.getElementById('search-input').value = q;
      handleSearch(new Event('submit'));
    }
  })();
</script>
