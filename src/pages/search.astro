---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 构建搜索索引：提取精简字段供客户端使用
const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const index = allPosts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description || '',
  date: p.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }),
  tags: p.data.tags || [],
  cover: p.data.cover || '',
  body: (p.body || '').slice(0, 500) // 只取前 500 字符做索引
}));
---

<BaseLayout title="搜索">
  <article class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-12 animate-fade-in">
      <h1 class="text-4xl md:text-5xl font-headline font-semibold tracking-tight text-[rgb(var(--fg))]">
        搜索
      </h1>
      <form id="search-form" action="/search" method="get" class="mt-6" onsubmit="handleSearch(event)">
        <input
          type="search"
          id="search-input"
          name="q"
          placeholder="输入关键词..."
          autofocus
          class="w-full max-w-xl px-4 py-3 rounded-lg bg-[rgb(var(--bg-soft))] border border-[rgb(var(--border))]/50 text-[rgb(var(--fg))] placeholder:text-[rgb(var(--fg-soft))] focus:outline-none focus:border-[rgb(var(--primary))] focus:ring-1 focus:ring-[rgb(var(--primary))]/30 transition-colors"
        />
      </form>
    </header>

    <p id="search-info" class="text-[rgb(var(--fg-soft))] mb-8 hidden"></p>

    <div id="search-results" class="grid sm:grid-cols-2 gap-6"></div>

    <p id="search-empty" class="text-[rgb(var(--fg-soft))] text-center py-12 hidden">
      没有找到相关文章
    </p>
  </article>
</BaseLayout>

<!-- 搜索索引（JSON，供客户端 JS 使用） -->
<script is:inline>
  window.__SEARCH_INDEX__ = {JSON.stringify(index)};
</script>

<script is:inline>
  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderCard(post) {
    const coverHtml = post.cover
      ? `<div class="overflow-hidden rounded-xl mb-5 aspect-[16/9] bg-[rgb(var(--bg-soft))] relative">
           <img src="${escapeHtml(post.cover)}" alt="${escapeHtml(post.title)}" loading="lazy"
                class="w-full h-full object-cover">
         </div>`
      : '';

    const tagsHtml = post.tags.length
      ? `<div class="flex flex-wrap gap-2">
           ${post.tags.slice(0, 4).map((t, i) => {
             const colors = [
               'background: rgb(var(--post-it-yellow, 255, 236, 179)); color: rgb(var(--post-it-text, 86, 31, 0));',
               'background: rgba(var(--secondary), 0.15); color: rgb(var(--secondary));',
               'background: rgba(var(--sage, 177, 207, 167), 0.15); color: rgb(var(--tertiary));',
               'background: rgba(var(--surface-variant), 0.3); color: rgb(var(--fg-soft));'
             ];
             return `<span class="postit-tag" style="${colors[i % 4]}">#${escapeHtml(t)}</span>`;
           }).join('')}
         </div>`
      : '';

    return `
      <article class="group scrapbook-card rounded-[2rem] p-6 magnetic-hover relative" style="transform: rotate(0deg);">
        <a href="/posts/${post.slug}/" class="block h-full">
          ${coverHtml}
          <div class="space-y-3">
            <div class="flex items-center gap-2 flex-wrap text-xs text-[rgb(var(--fg-soft))] font-body">
              <time class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">calendar_today</span>
                ${escapeHtml(post.date)}
              </time>
            </div>
            ${tagsHtml}
            <h3 class="font-headline font-semibold tracking-tight text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors text-lg md:text-xl">
              ${escapeHtml(post.title)}
            </h3>
            ${post.description ? `<p class="text-[rgb(var(--fg-soft))] line-clamp-2 leading-relaxed text-sm font-body">${escapeHtml(post.description)}</p>` : ''}
            <div class="flex items-center text-[rgb(var(--primary))] text-sm font-label font-semibold">
              阅读全文
              <span class="material-symbols-outlined text-base ml-1">arrow_forward</span>
            </div>
          </div>
        </a>
      </article>`;
  }

  function handleSearch(e) {
    e.preventDefault();
    const query = document.getElementById('search-input').value.trim().toLowerCase();
    const infoEl = document.getElementById('search-info');
    const resultsEl = document.getElementById('search-results');
    const emptyEl = document.getElementById('search-empty');

    if (!query) {
      infoEl.classList.add('hidden');
      resultsEl.innerHTML = '';
      emptyEl.classList.add('hidden');
      // 更新 URL 不刷新页面
      history.replaceState(null, '', '/search');
      return;
    }

    // 更新 URL
    history.replaceState(null, '', `/search?q=${encodeURIComponent(query)}`);

    const posts = window.__SEARCH_INDEX__ || [];
    const results = posts.filter(p =>
      p.title.toLowerCase().includes(query) ||
      p.description.toLowerCase().includes(query) ||
      p.tags.some(t => t.toLowerCase().includes(query)) ||
      p.body.toLowerCase().includes(query)
    );

    infoEl.classList.remove('hidden');
    infoEl.innerHTML = `关于「<span class="text-[rgb(var(--primary))] font-medium">${escapeHtml(query)}</span>」找到 ${results.length} 个结果`;

    if (results.length > 0) {
      resultsEl.innerHTML = results.map(renderCard).join('');
      emptyEl.classList.add('hidden');
    } else {
      resultsEl.innerHTML = '';
      emptyEl.classList.remove('hidden');
    }
  }

  // 页面加载时读取 URL 中的查询参数并执行搜索
  (function () {
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q) {
      document.getElementById('search-input').value = q;
      handleSearch(new Event('submit'));
    }
  })();
</script>
