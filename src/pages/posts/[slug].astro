---
import type { GetStaticPaths } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import TwikooComments from '../../components/TwikooComments.astro';
import { getReadingTime } from '../../utils/readingTime';
import site from '../../site.json';
const SITE = site;

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection('posts');
  // 按日期升序排列，用于确定文章的先后顺序
  const sorted = all
    .filter(p => !p.data.draft)
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  // 必须遍历排序后的数组，确保索引 i 与 prev/next 对应正确
  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i - 1] || null,
      next: sorted[i + 1] || null
    }
  }));
};

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await post.render();
const { data, slug } = post;

// 按中文字数+英文词数精确估算阅读时间
const readTime = getReadingTime(post.body);

const dateStr = data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// 更新日期（当存在且不同于发布日期时显示）
const hasUpdate = data.updated
  && data.updated.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) !== dateStr;
const updatedStr = data.updated
  ? data.updated.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// 取 h2/h3 作为目录
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);

// 收集全部文章（给 Sidebar）
const allPosts = (await getCollection('posts')).filter(p => !p.data.draft);
---

<BaseLayout title={data.title} description={data.description} current={`/posts/${slug}/`}>
  <div slot="sidebar">
    <Sidebar posts={allPosts} />
  </div>

  <!-- 阅读进度条 -->
  <div id="reading-progress" class="reading-progress no-print"></div>

  <article class="pb-8 onload-animation">
    <a
      href="/"
      class="no-print inline-flex items-center gap-1 text-sm text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-all ios-press mb-4"
    >
      <span class="material-symbols-outlined text-base">arrow_back</span>
      返回文章
    </a>

    <div class="flex flex-col lg:flex-row lg:gap-8">
      <div class="flex-1 min-w-0">
        <header class="mb-8">
          <div class="flex items-center gap-2 flex-wrap text-sm text-[rgb(var(--fg-soft))] mb-4 font-body">
            <time datetime={data.date.toISOString()}>
              <span class="material-symbols-outlined text-sm align-middle mr-1">calendar_today</span>
              {dateStr}
            </time>
            <span>·</span>
            <span class="flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">schedule</span>
              {readTime} 分钟阅读
            </span>
            {hasUpdate && (
              <>
                <span>·</span>
                <span class="flex items-center gap-1 text-[rgb(var(--secondary))]">
                  <span class="material-symbols-outlined text-sm">edit</span>
                  更新于 {updatedStr}
                </span>
              </>
            )}
            {data.tags && data.tags.length > 0 && (
              <>
                <span>·</span>
                <div class="flex gap-1.5 flex-wrap">
                  {data.tags.map(t => (
                    <a href={`/tags/${t}`} class="tag-chip">#{t}</a>
                  ))}
                </div>
              </>
            )}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-[rgb(var(--fg))] leading-tight">
            {data.title}
          </h1>

          {data.description && (
            <p class="mt-4 text-lg text-[rgb(var(--fg-soft))] leading-relaxed">
              {data.description}
            </p>
          )}
        </header>

        {data.cover && (
          <img
            src={data.cover}
            alt={data.title}
            class="w-full rounded-2xl mb-8 shadow-sm cursor-zoom-in"
            loading="lazy"
          />
        )}

        <div class="prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>

        <!-- 点赞 -->
        <div class="no-print mt-10 pt-6 border-t border-dashed border-[rgb(var(--border))]/40 flex items-center justify-between flex-wrap gap-4">
          <button
            id="like-btn"
            class="group flex items-center gap-2 px-5 py-2.5 rounded-2xl border border-[rgb(var(--border))]/60 hover:border-[rgb(var(--primary))]/40 hover:bg-[rgb(var(--primary-light))]/5 transition-all ios-press"
          >
            <span id="like-heart" class="material-symbols-outlined text-[rgb(var(--fg-soft))] group-hover:text-[rgb(var(--primary))] transition-colors text-2xl">favorite</span>
            <span class="text-sm text-[rgb(var(--fg-soft))] group-hover:text-[rgb(var(--primary))] transition-colors">
              <span id="like-count">0</span> 个赞
            </span>
          </button>

          <div class="text-xs text-[rgb(var(--fg-soft))] font-body">
            本文采用
            <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener" class="text-[rgb(var(--primary))] hover:text-[rgb(var(--primary-light))] transition-colors">CC BY-NC 4.0</a>
            协议
          </div>
        </div>

        <!-- 上下篇 -->
        <nav class="no-print mt-10 grid sm:grid-cols-2 gap-4">
          {prev && (
            <a
              href={`/posts/${prev.slug}/`}
              class="group card-base rounded-2xl p-5 ios-press"
            >
              <div class="text-xs text-[rgb(var(--fg-soft))] mb-1 font-handwritten">← 上一篇</div>
              <div class="text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors font-medium line-clamp-2">
                {prev.data.title}
              </div>
            </a>
          )}
          {next && (
            <a
              href={`/posts/${next.slug}/`}
              class={`group card-base rounded-2xl p-5 text-right ios-press ${!prev ? 'sm:col-start-2' : ''}`}
            >
              <div class="text-xs text-[rgb(var(--fg-soft))] mb-1 font-handwritten">下一篇 →</div>
              <div class="text-[rgb(var(--fg))] group-hover:text-[rgb(var(--primary))] transition-colors font-medium line-clamp-2">
                {next.data.title}
              </div>
            </a>
          )}
        </nav>

        <!-- 评论 -->
        <section class="no-print mt-12">
          <h2 class="text-2xl font-bold text-[rgb(var(--fg))] mb-6 flex items-center gap-2 font-headline">
            <span class="w-1.5 h-6 rounded-full" style="background: linear-gradient(to bottom, rgb(var(--primary)), rgb(var(--secondary)));"></span>
            留言
          </h2>
          {SITE.twikoo && SITE.twikoo.enabled ? (
            <div class="liquid-glass rounded-[2rem] p-6">
              <TwikooComments />
              <div class="flex items-center justify-between mt-3 flex-wrap gap-2">
                <p class="text-xs text-[rgb(var(--fg-soft))] font-handwritten">
                  💬 评论由
                  <a href="https://twikoo.js.org/" target="_blank" rel="noopener" class="text-[rgb(var(--primary))] hover:text-[rgb(var(--primary-light))] transition-colors">Twikoo</a>
                  驱动
                </p>
                <button
                  id="copy-link-btn"
                  class="text-xs text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-all inline-flex items-center gap-1 cursor-pointer ios-press"
                  title="复制本页链接"
                >
                  <span class="material-symbols-outlined text-sm">link</span>
                  <span id="copy-link-label">复制链接</span>
                </button>
              </div>
            </div>
          ) : (
            <div class="liquid-glass rounded-[2rem] p-8 text-center">
              <span class="material-symbols-outlined text-5xl text-[rgb(var(--fg-soft))] opacity-40 mb-4 block">forum</span>
              <p class="text-[rgb(var(--fg-soft))] font-handwritten text-lg mb-4">
                评论功能尚未开启
              </p>
              <p class="text-sm text-[rgb(var(--fg-soft))]/60">
                等我部署好 Twikoo 就上线啦～
              </p>
            </div>
          )}
        </section>
      </div>

      <!-- 文章目录 (Fuwaari-style TOC on right) -->
      {toc.length > 0 && (
        <aside class="hidden 2xl:block no-print shrink-0" style="width: var(--toc-width, 14rem);">
          <div id="toc-wrapper" class="sticky top-24">
            <div class="h-full overflow-y-auto overflow-x-hidden hide-scrollbar" style="max-height: calc(100vh - 8rem);">
              <h4 class="text-xs font-bold text-[rgb(var(--primary))] uppercase tracking-wider mb-3 flex items-center gap-1.5">
                <span class="material-symbols-outlined text-sm">toc</span>
                目录
              </h4>
              <ul class="space-y-1 text-sm">
                {toc.map(h => (
                  <li class={h.depth === 3 ? 'pl-5' : 'pl-0'}>
                    <a
                      href={`#${h.slug}`}
                      class="text-[rgb(var(--fg-soft))] hover:text-[rgb(var(--primary))] transition-all block py-1 border-l-2 border-transparent hover:border-[rgb(var(--primary))] -ml-px pl-2 text-sm ios-press"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>
      )}
    </div>
  </article>

  <script is:inline define:vars={{ slug }}>
    // 点赞功能 (持久化 via Twikoo API + MongoDB)
    const LIKE_API = window.__TWIKOO_CONFIG__?.envId 
      ? window.__TWIKOO_CONFIG__.envId.replace(/\/+$/, '')
      : null;
    const STORAGE_KEY = `liked_${slug}`;
    const alreadyLiked = localStorage.getItem(STORAGE_KEY) === 'true';
    const countEl = document.getElementById('like-count');
    const btn = document.getElementById('like-btn');
    const heartIcon = document.getElementById('like-heart');

    // 调用 Twikoo 后端 API
    async function callLikeAPI(event) {
      if (!LIKE_API) return null;
      try {
        const res = await fetch(LIKE_API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ event, url: slug })
        });
        const data = await res.json();
        if (data.code === 0 && data.data) return data.data;
        return null;
      } catch (e) {
        console.warn('Like API error:', e);
        return null;
      }
    }

    // 从服务器读取当前点赞数
    async function fetchCount() {
      const result = await callLikeAPI('POST_LIKE_GET');
      if (result && countEl) {
        countEl.textContent = result.count ?? 0;
      }
      if (alreadyLiked && heartIcon) {
        heartIcon.style.fontVariationSettings = "'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24";
        heartIcon.classList.add('text-[rgb(var(--primary))]');
      }
    }
    fetchCount();

    // 加载完成后立即检查是否已赞过
    if (alreadyLiked && heartIcon) {
      heartIcon.style.fontVariationSettings = "'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24";
      heartIcon.classList.add('text-[rgb(var(--primary))]');
    }

    btn?.addEventListener('click', async () => {
      if (alreadyLiked) return; // 每人只能赞一次

      // 乐观更新 UI
      const current = parseInt(countEl?.textContent || '0', 10);
      if (countEl) countEl.textContent = current + 1;
      if (heartIcon) {
        heartIcon.style.fontVariationSettings = "'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24";
        heartIcon.classList.add('text-[rgb(var(--primary))]');
      }
      btn.classList.add('scale-110');
      setTimeout(() => btn.classList.remove('scale-110'), 200);

      // 持久化到服务器
      if (LIKE_API) {
        try {
          const result = await callLikeAPI('POST_LIKE_SET');
          if (result && countEl) {
            // 用服务器返回的准确值覆盖
            countEl.textContent = result.count;
          }
          localStorage.setItem(STORAGE_KEY, 'true');
        } catch (e) {
          console.warn('Failed to save like:', e);
          // 失败时回滚
          if (countEl) countEl.textContent = current;
          if (heartIcon) {
            heartIcon.style.fontVariationSettings = "'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24";
            heartIcon.classList.remove('text-[rgb(var(--primary))]');
          }
        }
      } else {
        // 降级：仅本地
        localStorage.setItem(STORAGE_KEY, 'true');
      }
    });

    // 阅读进度条
    const progress = document.getElementById('reading-progress');
    function updateProgress() {
      const article = document.querySelector('article');
      if (!article || !progress) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = -rect.top;
      const percent = Math.max(0, Math.min(100, (scrolled / total) * 100));
      progress.style.width = `${percent}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // FancyBox：文章内图片点击放大 + 图库导航
    (function() {
      // 为 .prose 内所有图片添加 data-fancybox 属性（形成图库，可前后切换）
      document.querySelectorAll('.prose img:not(.no-zoom)').forEach(function(img) {
        img.setAttribute('data-fancybox', 'article-gallery');
      });

      // 动态加载 FancyBox UMD（仅在文章页按需加载）
      var s = document.createElement('script');
      s.src = '/fancybox/fancybox.umd.js';
      s.onload = function() {
        Fancybox.bind('[data-fancybox="article-gallery"]', {
          Carousel: { infinite: false },
          Toolbar: {
            display: {
              left: [],
              middle: ['infobar'],
              right: ['slideshow', 'download', 'close'],
            },
          },
          Thumbs: { autoStart: false },
        });
      };
      document.head.appendChild(s);
    })();

    // 复制链接
    const copyBtn = document.getElementById('copy-link-btn');
    const copyLabel = document.getElementById('copy-link-label');
    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyLabel.textContent = '已复制';
        setTimeout(() => { copyLabel.textContent = '复制链接'; }, 2000);
      } catch {
        copyLabel.textContent = '复制失败';
      }
    });
  </script>

  <!-- 配置注入已交由 TwikooComments 组件处理 -->
</BaseLayout>
