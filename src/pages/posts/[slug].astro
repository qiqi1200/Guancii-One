---
import type { GetStaticPaths } from 'astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TwikooComments from '../../components/TwikooComments.astro';
import site from '../../site.json';
const SITE = site;

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts');
  const sorted = posts.sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime()
  );
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i - 1] || null,
      next: sorted[i + 1] || null
    }
  }));
};

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await post.render();
const { data, slug } = post;

// 估算阅读时间
const wordCount = post.body.length;
const readTime = Math.max(1, Math.ceil(wordCount / 400));

const dateStr = data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// 取 h2/h3 作为目录
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---
<BaseLayout title={data.title} description={data.description} current={`/posts/${slug}/`}>
  <!-- 阅读进度条 -->
  <div id="reading-progress" class="reading-progress no-print"></div>

  <article class="max-w-6xl mx-auto px-6 py-8 md:py-12">
    <a
      href="/"
      class="no-print inline-flex items-center gap-1 text-sm text-ink-400 dark:text-cream-300 hover:text-accent-sky transition-colors mb-8"
    >
      ← 返回首页
    </a>

    <div class="grid lg:grid-cols-[1fr_240px] gap-12">
      <div>
        <header class="mb-10 animate-fade-in">
          <div class="flex items-center gap-2 flex-wrap text-sm text-ink-400 dark:text-cream-300 mb-4">
            <time datetime={data.date.toISOString()}>{dateStr}</time>
            <span>·</span>
            <span>{readTime} 分钟阅读</span>
            {data.tags && data.tags.length > 0 && (
              <>
                <span>·</span>
                <div class="flex gap-1.5 flex-wrap">
                  {data.tags.map(t => (
                    <a href={`/tags/${t}`} class="tag-chip">#{t}</a>
                  ))}
                </div>
              </>
            )}
          </div>

          <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-ink-700 dark:text-cream-50 leading-tight">
            {data.title}
          </h1>

          {data.description && (
            <p class="mt-4 text-lg text-ink-500 dark:text-cream-300 leading-relaxed">
              {data.description}
            </p>
          )}
        </header>

        {data.cover && (
          <img
            src={data.cover}
            alt={data.title}
            class="w-full rounded-xl mb-10 shadow-sm animate-slide-up"
            loading="lazy"
          />
        )}

        <div class="prose prose-lg dark:prose-invert max-w-none animate-slide-up">
          <Content />
        </div>

        <!-- 点赞和分享 -->
        <div class="no-print mt-12 pt-8 border-t border-cream-200 dark:border-ink-600 flex items-center justify-between flex-wrap gap-4">
          <button
            id="like-btn"
            class="group flex items-center gap-2 px-4 py-2 rounded-lg border border-cream-200 dark:border-ink-600 hover:border-accent-sky hover:bg-accent-sky/5 transition-all"
          >
            <svg class="w-5 h-5 text-ink-400 group-hover:text-accent-sky transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="text-sm text-ink-500 dark:text-cream-300 group-hover:text-accent-sky">
              <span id="like-count">0</span> 个赞
            </span>
          </button>

          <div class="text-xs text-ink-400 dark:text-cream-300">
            本文采用
            <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener" class="text-accent-sky hover:underline">CC BY-NC 4.0</a>
            协议
          </div>
        </div>

        <!-- 上下篇 -->
        <nav class="no-print mt-12 grid sm:grid-cols-2 gap-4">
          {prev && (
            <a
              href={`/posts/${prev.slug}/`}
              class="group p-5 rounded-xl border border-cream-200 dark:border-ink-600 hover:border-accent-sky transition-colors"
            >
              <div class="text-xs text-ink-400 dark:text-cream-300 mb-1">← 上一篇</div>
              <div class="text-ink-700 dark:text-cream-50 group-hover:text-accent-sky transition-colors font-medium line-clamp-2">
                {prev.data.title}
              </div>
            </a>
          )}
          {next && (
            <a
              href={`/posts/${next.slug}/`}
              class={`group p-5 rounded-xl border border-cream-200 dark:border-ink-600 hover:border-accent-sky transition-colors text-right ${!prev ? 'sm:col-start-2' : ''}`}
            >
              <div class="text-xs text-ink-400 dark:text-cream-300 mb-1">下一篇 →</div>
              <div class="text-ink-700 dark:text-cream-50 group-hover:text-accent-sky transition-colors font-medium line-clamp-2">
                {next.data.title}
              </div>
            </a>
          )}
        </nav>

        <!-- 评论 -->
        <section class="no-print mt-16">
          <h2 class="text-2xl font-semibold text-ink-700 dark:text-cream-50 mb-6 flex items-center gap-2">
            <span class="w-1 h-6 bg-accent-sky rounded"></span>
            留言
          </h2>
          {SITE.twikoo && SITE.twikoo.enabled ? (
            <div class="rounded-xl bg-cream-100/50 dark:bg-ink-600/30 p-6">
              <TwikooComments />
              <p class="text-xs text-ink-400 dark:text-cream-300 mt-3">
                💬 评论由
                <a href="https://twikoo.js.org/" target="_blank" rel="noopener" class="text-accent-sky hover:underline">Twikoo</a>
                驱动 · 部署后请把 <code class="px-1 py-0.5 rounded bg-cream-200 dark:bg-ink-700 text-accent-sky">envId</code> 改成你的服务地址
              </p>
            </div>
          ) : (
            <p class="text-ink-400 dark:text-cream-300">评论功能未启用</p>
          )}
        </section>
      </div>

      <!-- 文章目录 -->
      {toc.length > 0 && (
        <aside class="hidden lg:block no-print">
          <div class="sticky top-24">
            <h4 class="text-xs font-semibold text-ink-400 dark:text-cream-300 uppercase tracking-wider mb-3">
              目录
            </h4>
            <ul class="space-y-1.5 text-sm border-l border-cream-200 dark:border-ink-600">
              {toc.map(h => (
                <li class={h.depth === 3 ? 'pl-6' : 'pl-3'}>
                  <a
                    href={`#${h.slug}`}
                    class="text-ink-500 dark:text-cream-300 hover:text-accent-sky transition-colors block py-0.5 border-l-2 border-transparent hover:border-accent-sky -ml-px pl-2"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>
      )}
    </div>
  </article>

  <script is:inline define:vars={{ slug }}>
    // 点赞功能 (localStorage)
    const STORAGE_KEY = `likes_${slug}`;
    const stored = localStorage.getItem(STORAGE_KEY);
    const countEl = document.getElementById('like-count');
    const btn = document.getElementById('like-btn');

    if (countEl) {
      // 基础随机种子 + 已点赞状态
      const baseCount = parseInt(stored || '0', 10);
      countEl.textContent = baseCount;
    }

    btn?.addEventListener('click', () => {
      const current = parseInt(localStorage.getItem(STORAGE_KEY) || '0', 10);
      const next = current + 1;
      localStorage.setItem(STORAGE_KEY, String(next));
      if (countEl) {
        countEl.textContent = next;
        btn.classList.add('scale-110');
        setTimeout(() => btn.classList.remove('scale-110'), 200);
      }
    });

    // 阅读进度条
    const progress = document.getElementById('reading-progress');
    function updateProgress() {
      const article = document.querySelector('article');
      if (!article || !progress) return;
      const rect = article.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = -rect.top;
      const percent = Math.max(0, Math.min(100, (scrolled / total) * 100));
      progress.style.width = `${percent}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // 监听暗色模式切换，更新 Twikoo 主题
    function updateTwikooTheme() {
      if (typeof twikoo === 'undefined') return;
      const theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      twikoo.setDarkMode(theme);
    }
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      setTimeout(updateTwikooTheme, 100);
    });
  </script>

  <!-- 把 site.json 的 twikoo 配置注入到 window 供 TwikooComments 组件使用 -->
  <script is:inline define:vars={{ twikooConfig: SITE.twikoo }}>
    window.__TWIKOO_CONFIG__ = twikooConfig;
  </script>
</BaseLayout>
