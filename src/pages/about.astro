---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.json';
const SITE = site;

const skills = {
  '在学': ['TypeScript', 'Python', 'Astro', 'Tailwind CSS'],
  '折腾': ['前端开发', '博客搭建', 'Linux']
};

const timeline = [
  { year: '2025 - 现在', title: '中国民航大学 · 交通工程 · 大一', desc: '写写博客，学点代码，记录生活' },
  { year: '2025', title: '高考结束，进入大学', desc: '开始接触编程和独立博客' }
];
---
<BaseLayout title="关于" current="/about">
  <article class="max-w-3xl mx-auto px-6 py-12 md:py-20">
    <header class="mb-12 animate-fade-in">
      <div class="text-sm text-[rgb(var(--fg-soft))] mb-2 font-handwritten">关于</div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[rgb(var(--fg))]">
        关于我
      </h1>
      <p class="mt-4 text-lg text-[rgb(var(--fg-soft))] leading-relaxed font-body">
        一个在路上找方向的大学生。
      </p>
    </header>

    <div class="space-y-6 text-[rgb(var(--fg))] font-body leading-relaxed">
      <p>
        你好，我是 <strong>guancii</strong>，来自吉林四平，
        目前在中国民航大学读交通工程，大一。
      </p>
      <p>
        这个角落用来记录生活里的小事、学到的零碎知识、还有偶尔的胡思乱想。
        没什么宏大的规划，就是觉得值得记下来的东西就写一写。
      </p>
      <p>
        写东西更多是为了整理自己的思路。
        如果刚好有人读到并觉得有点意思，那就是意外之喜了。
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[rgb(var(--primary))]">school</span>
        学校
      </h2>
      <ul class="space-y-2">
        <li class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[rgb(var(--primary))] text-sm">location_on</span>
          中国民航大学（CAUC）· 天津
        </li>
        <li class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[rgb(var(--primary))] text-sm">book</span>
          交通工程 · 大一
        </li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[rgb(var(--primary))]">code</span>
        在折腾什么
      </h2>
      {Object.entries(skills).map(([level, items]) => (
        <div class="mb-4">
          <p class="font-handwritten text-[rgb(var(--secondary))] mb-2">{level}</p>
          <div class="flex flex-wrap gap-2">
            {items.map(s => (
              <span class="postit-tag" style="background: rgba(var(--primary-light), 0.12); color: rgb(var(--primary));">
                {s}
              </span>
            ))}
          </div>
        </div>
      ))}

      <h2 class="text-2xl font-bold mt-10 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[rgb(var(--primary))]">timeline</span>
        时间线
      </h2>
      <div class="space-y-6">
        {timeline.map((t, i) => (
          <div class="liquid-glass rounded-xl p-5 hover:translate-x-1 transition-transform duration-300 scroll-reveal" style={`--reveal-delay: ${i * 100}ms`}>
            <div class="text-sm text-[rgb(var(--primary))] font-handwritten">{t.year}</div>
            <div class="font-semibold mt-1">{t.title}</div>
            <div class="text-sm text-[rgb(var(--fg-soft))] mt-1">{t.desc}</div>
          </div>
        ))}
      </div>

      <h2 class="text-2xl font-bold mt-10 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-[rgb(var(--primary))]">mail</span>
        找到我
      </h2>
      <p class="text-[rgb(var(--fg-soft))]">
        不怎么活跃，但欢迎来聊：<br />
        GitHub：<a href={SITE.links.github} target="_blank" rel="noopener" class="text-[rgb(var(--primary))] hover:text-[rgb(var(--primary-light))] transition-colors">@{SITE.author}</a><br />
        邮箱：<a href={SITE.links.email} class="text-[rgb(var(--primary))] hover:text-[rgb(var(--primary-light))] transition-colors">vivia-qiqi@outlook.com</a>
      </p>

      <blockquote class="border-l-4 border-[rgb(var(--primary))] pl-4 italic text-[rgb(var(--fg-soft))] font-handwritten mt-8">
        「慢慢来，比较快。」
      </blockquote>
    </div>
  </article>
</BaseLayout>
